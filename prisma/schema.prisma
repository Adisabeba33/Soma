// SOMA - Sensory Sommelier for Cannabis
// PostgreSQL schema for users, taste profiles, analysis sessions,
// recommendations and the feedback loop.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  // Account fields (real registration). All optional so existing anonymous-
  // cookie users stay valid; a User becomes "registered" when username/
  // passwordHash are set on its existing row, so its history carries over.
  // emailVerified stays null until the user confirms via the emailed link.
  username      String?   @unique
  passwordHash  String?
  emailVerified DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasteProfiles    TasteProfile[]
  analysisSessions AnalysisSession[]
  feedback         Feedback[]
  strainFeedback   StrainFeedback[]
  unknownStrains   UnknownStrain[]
  runAudits        RunAudit[]
  authTokens       AuthToken[]
}

// Single-use, hashed tokens for email verification and password reset. The raw
// token is emailed to the user; only its sha256 hash is stored, so a DB leak
// cannot be used to verify an email or reset a password. Deleted on use, and
// ignored past expiresAt.
model AuthToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  type      String // "email_verify" | "password_reset"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model TasteProfile {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteStrains    String[]
  dislikedStrains    String[]
  likedTraits        String[]
  dislikedTraits     String[]
  preferredAromas    String[]
  preferredFlavors   String[]
  preferredEffects   String[]
  // Effects to actively avoid (symmetric with preferredEffects). Default
  // empty so existing rows stay valid without a backfill migration.
  dislikedEffects    String[] @default([])
  // Aromas/flavours to actively avoid (symmetric with preferredAromas).
  // Default empty so existing rows stay valid without a backfill.
  dislikedAromas     String[] @default([])
  texturePreferences String[]
  qualityPriorities  String[]
  referenceStrain    String?
  lookingFor         String?  @default("similar") // "similar" replacement or "new" experience
  // Forced-choice dimensions (see src/lib/profile-target.ts). Nullable so
  // existing rows stay valid; drive the scoring target directly when present.
  primaryAroma       String?  // gas | earthfunk | citrus | sweet | fruit | pineherb
  primaryEffect      String?  // calm | knockout | social | lifted | sharp
  useTime            String?  // morning | daytime | evening | bed
  // How the person consumes: joint | blunt | pipe | bong | vape. Nullable so
  // existing rows stay valid; contextual signal for future logic.
  smokingMethod      String?
  bodyFeel           Int?     // 0 (clear/light) .. 100 (heavy/couch-lock)
  potencyPreference  String?  // mild | balanced | strong (how hard-hitting)
  // Strain "families" the user seeks out / usually avoids (buying behaviour,
  // distinct from sensory match). Named-family keys; see src/lib/strain-families.ts.
  preferredFamilies  String[] @default([])
  avoidedFamilies    String[] @default([])
  // Soft sativa-risk dimensions the user opts out of (see src/lib/risk-tags.ts,
  // currently "racy"). Penalises only opted-out users. Default empty so existing
  // rows stay valid without a backfill.
  avoidedRisks       String[] @default([])
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  analysisSessions AnalysisSession[]

  @@index([userId])
}

model AnalysisSession {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasteProfileId String?
  tasteProfile   TasteProfile? @relation(fields: [tasteProfileId], references: [id], onDelete: SetNull)
  inputType      String   // manual | paste | screenshot
  rawInput       String
  saved          Boolean  @default(false)
  title          String?
  engine         String   @default("builtin") // builtin | openai
  parsedItems    Json?    // ParsedMenuItem[] captured from the menu parser
  parserWarnings String[] @default([]) // distinct warning strings surfaced by the parser
  menuQuality    Json?    // { totalParsed, unclearRows, unknownStrains, avgConfidence }
  createdAt      DateTime @default(now())

  recommendations Recommendation[]
  unknownStrains  UnknownStrain[]

  @@index([userId])
}

model Recommendation {
  id                 String   @id @default(uuid())
  sessionId          String
  session            AnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  strainName         String
  resolvedName       String
  knownStrain        Boolean  @default(true)
  category           String   // Best Match | Closest Alternative | Worth Trying | Risky | Avoid
  matchScore         Int      // sensory match (0–99)
  confidence         String   // sensory confidence: low | medium | high
  aromaMatch         Int
  flavorMatch        Int
  effectMatch        Int
  whyItFits          String
  riskNotes          String
  explanation        String
  feedbackNote       String?
  // Second axis — see src/lib/purchase-confidence.ts. Nullable so old rows
  // stay valid; readers default to all-"unknown".
  purchaseConfidence Json?
  createdAt          DateTime @default(now())

  feedback Feedback[]

  @@index([sessionId])
}

model Feedback {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  purchased        Boolean?
  liked            Boolean?
  rating           Int?
  notes            String?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([recommendationId])
}

// Lightweight strain-level verdict, captured from quick-rate pills on
// Compare results and (later) Taste Match results. The original
// Feedback model is tied to a saved Recommendation row; this one is
// keyed directly on the strain so a single tap right after a Compare
// run can persist without first turning the result into a
// Recommendation. Read by the engine's evaluateFeedback() loop so
// every future scoreStrain call across this user reflects accumulated
// verdicts. Latest-write-wins on (userId, strainName).
//
// verdict values: "loved" | "good" | "neutral" | "avoid"
// source values:  informational, "compare" | "taste-match" | "catalog"
model StrainFeedback {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strainName String   // resolved canonical name
  verdict    String
  source     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, strainName])
  @@index([userId])
}

// Real-world expansion queue. Anything the engine had to infer (i.e. not in
// the seed dataset) is logged here so we can grow the seed list based on
// what actually shows up on dispensary menus. Deduped per user on
// (normalizedName, growerKey) so a recurring "Gelato" doesn't blow up the
// table — repeats bump `occurrences` and `lastSeenAt` instead.
model UnknownStrain {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId      String?
  session        AnalysisSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  rawName        String
  normalizedName String
  grower         String?
  growerKey      String   @default("")
  rawLine        String?
  occurrences    Int      @default(1)
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@unique([userId, normalizedName, growerKey])
  @@index([userId])
  @@index([normalizedName])
  @@index([lastSeenAt])
}

// Engine run audit log. Every successful /api/analyze (Taste Match) and
// /api/compare (Compare) run writes one row with the full snapshot
// (profile, parsed items, behavioural mode, recommendations,
// contradictions). The `source` field on the snapshot distinguishes the
// two entry paths. Persists to the same Postgres as the rest of the app
// so it survives serverless deploys (Vercel filesystem is ephemeral).
// Owner-only via /api/audit/export.
model RunAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    String   // "compare" | "taste-match"
  runAt     DateTime @default(now())
  snapshot  Json

  @@index([userId])
  @@index([runAt])
  @@index([source])
}

// Describe-intake telemetry. Every /api/profile/from-description submission
// writes one row: the raw phrasing, the sensory/effect tokens the parser
// resolved, and — most valuably — the content words that mapped to NOTHING
// (`leftoverTerms`), which are the candidates for new synonyms. Drives
// evidence-based growth of the describe parser (see docs/deferred-improvements
// #18). Deliberately NOT tied to User: this is anonymous intake text, kept
// aggregate-only. Persists to Postgres so it survives serverless deploys.
model DescribeAudit {
  id            String   @id @default(uuid())
  rawText       String
  // Tokens the parser understood (aromas/flavors/effects/time/etc).
  matchedTokens String[] @default([])
  // Content words that matched no trigger — the growth signal.
  leftoverTerms String[] @default([])
  // Did the description yield a usable profile at all.
  hadSignal     Boolean  @default(false)
  vocabVersion  String
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([hadSignal])
}
