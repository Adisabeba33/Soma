# PostgreSQL / Supabase connection string (required).
DATABASE_URL="postgresql://user:password@localhost:5432/soma?schema=public"

# Optional: an AI provider key unlocks two AI layers. When unset, SOMA runs
# fully deterministic (built-in Taste Match Engine + keyword fallback for
# strains not in the catalog) — nothing else needs changing.
#   1. AI sommelier prose (rewrites explanations; never changes scores).
#   2. AI strain inference: strains a user enters that aren't in the catalog
#      get a sensory profile from the model, constrained to SOMA's vocabulary,
#      and are scored like any strain (shown as an estimate, not curated).
#
# Provider selection: Claude (Anthropic) is the primary provider; OpenAI is a
# selectable option. AI_PROVIDER picks the preferred one ("claude" | "openai",
# default "claude"); each is gated on its own key, and SOMA falls back to the
# other provider if the preferred one has no key.
AI_PROVIDER="claude"
# Claude (primary). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-haiku-4-5"
# OpenAI (option). Used when AI_PROVIDER="openai", or as a fallback.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Set STRAIN_AI="off" to keep the prose layer but disable strain inference.
STRAIN_AI=""

# Accounts (email + password registration). Signs the session cookie. Without
# it, login is dormant and the app works anonymously (cookie identity) as before.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=""
# Resend email (verification + password reset) is wired in a later phase:
# RESEND_API_KEY="" / EMAIL_FROM="" / NEXT_PUBLIC_APP_URL=""
