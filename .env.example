# PostgreSQL / Supabase connection string (required).
DATABASE_URL="postgresql://user:password@localhost:5432/soma?schema=public"

# Optional: a single key unlocks the AI layers. When unset, SOMA runs fully
# deterministic (built-in engine + keyword parsers) — nothing else needs change.
#   1. AI sommelier prose (rewrites explanations; never changes scores).
#   2. AI strain inference: strains not in the catalog get a vocab-constrained
#      sensory profile from the model, scored like any strain (shown as estimate).
#   3. AI describe intake: a free-text description ("makes me want to clean the
#      house, lemon-gas smell, nothing racy") is translated into SOMA's tag
#      vocabulary on top of the deterministic parser, shown in the editable
#      preview. Constrained to the vocab; falls back to keywords on any failure.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Per-layer off switches (keep the prose layer, disable a specific extractor).
STRAIN_AI=""
DESCRIBE_AI=""
